rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/adminConfig/bootstrap)
        && get(/databases/$(database)/documents/adminConfig/bootstrap).data.uid == request.auth.uid;
    }

    match /adminConfig/bootstrap {
      allow get: if signedIn();
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/adminConfig/bootstrap)
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if signedIn()
        && (
          (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid)
          || isAdmin()
        );
      allow delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
