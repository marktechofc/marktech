rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para a coleção de pedidos
    match /pedidos/{pedidoId} {
      // Permitir leitura e escrita apenas se o usuário estiver autenticado
      // E apenas se o userId do documento for igual ao UID do usuário autenticado
      allow read, write: if request.auth != null 
        && request.auth.uid == resource.data.userId;
    }
    
    // Regras para outras coleções (se existirem)
    match /users/{userId} {
      allow read, write: if request.auth != null 
        && request.auth.uid == userId;
    }
    
    // Negar acesso a qualquer outra coleção que não seja explicitamente permitida
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
